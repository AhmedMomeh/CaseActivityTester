// =============================================================================
// CaseActivities appsettings snippet
// -----------------------------------------------------------------------------
// Paste this block into the host's appsettings.json. Two hosts need it:
//
//   1. C:\Program Files\Intalio\UC_CasePortal\appsettings.json   (runtime)
//   2. C:\Program Files\Intalio\UC_CaseDesigner\appsettings.json (testing in Designer)
//
// AND into the matching files on staging / production — same key names, only
// the values change per environment.
//
// Place "CaseActivities" as a sibling of "IdentityServer" / "StorageServerUrl".
// Don't forget the comma after the previous block.
//
// Missing keys throw a clear InvalidOperationException at activity startup —
// look in {LogDirectory}\<ActivityName>-YYYY-MM-DD.log for the key name if an
// activity fails to initialize.
// =============================================================================

"CaseActivities": {

  // --- Paths / endpoints not tied to a specific OAuth client ---------------
  "LogDirectory":   "C:\\Logs\\Case",
  "StorageBaseUrl": "http://localhost:44444/",
  "StampImagePath": "C:\\stamps\\approved.png",

  // --- IAM ------------------------------------------------------------------
  // IAM endpoint + the user account used by EVERY OAuth flow (password grant).
  // UserName/UserPassword are SHARED across all activities. Only the OAuth
  // client (ClientId/ClientSecret in CaseAuth and DmsAuth) differs per app.
  "IAM": {
    "IamBaseUrl":   "http://localhost:11111",
    "UserName":     "admin",
    "UserPassword": "1"
  },

  // --- OAuth client for the Case Portal app --------------------------------
  // Used by SendCaseDocumentsEmailActivity, BuildApprovalHistoryActivity,
  // and StampApprovedDocumentsActivity when calling Storage.
  "CaseAuth": {
    "ClientId":     "42faa0d5-9856-4639-9d73-36a5fb6bb561",
    "ClientSecret": "5b83f635-35d6-4d87-bda4-bbd471ce26c2"
  },

  // --- DMS endpoint + OAuth client -----------------------------------------
  // Used by ArchiveHRDocumentsToDMSActivity. UserId is the numeric DMS user id
  // required as the X-User-Id header by IntegrationService/UploadPage.
  "DmsAuth": {
    "DmsBaseUrl":   "http://localhost:8080/DMS/",
    "ClientId":     "398ff3ac-49b6-44fd-a70b-3cd69874c118",
    "ClientSecret": "ac63daac-edd5-496a-834f-e14a0e76c5c0",
    "UserId":       "1"
  },

  // --- Email (SendCaseDocumentsEmailActivity) ------------------------------
  // SMTP server settings come from the Portal's own configuration; this block
  // only configures recipients + template. Cc/Bcc may be empty strings, but
  // the KEYS must be present.
  "Email": {
    "FromDisplayName":     "Case Notifications",
    "ToRecipients":        "hr@intalio.com; archive@intalio.com; ahmed.abdelghany@intalio.com",
    "CcRecipients":        "",
    "BccRecipients":       "",
    "DefaultTemplateName": "OnCaseDocumentsForAction"
  }
}
